---
import { getCollection, render } from 'astro:content';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const policyEntries = await getCollection('policies');
  return policyEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<html lang="en">
	<head>
		<SEO 
			title={`${entry.data.title} | AutcustDev`}
			description={`Read the ${entry.data.title} for AutcustDev.`}
			type="article"
		/>

		<!-- Analytics -->
		<script defer src="/_vercel/insights/script.js"></script>
	</head>
	<body>
		<main class="container">
			<div class="glass-panel mb-4">
				<a href="/" class="mb-4" style="display: inline-block;">&larr; Back to Home</a>
				<h1>{entry.data.title}</h1>
				<p class="text-sm">Last updated: {entry.data.date.toDateString()}</p>
				<hr class="divider" />
				<div class="markdown-content">
					<Content />
				</div>
			</div>
		</main>
	</body>
</html>
