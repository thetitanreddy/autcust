---
import { getCollection } from 'astro:content';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const policies = await getCollection('policies');
---

<html lang="en">
	<head>
		<SEO 
			title="AutcustDev"
			description="AutcustDev Portfolio and Policies"
		/>

		<!-- Analytics -->
		<script defer src="/_vercel/insights/script.js"></script>
	</head>
	<body>
		<main class="container">
			<div class="glass-panel text-center mb-4">
				<h1>Welcome to AutcustDev</h1>
				<p>Managing apps like MileMint and TorrentX with a secure, maintenance-free infrastructure.</p>
				<a href="/admin" class="btn mt-4">Admin Dashboard</a>
			</div>
			
			<div class="glass-panel">
				<h2>Company Policies</h2>
				<p>Our policies are managed via Decap CMS and stored as Markdown, ensuring maximum performance, version control, and zero maintenance overhead.</p>
				<ul class="policy-list">
					{policies.map(policy => (
						<li>
							<a href={`/policies/${policy.id}`}>{policy.data.title}</a>
						</li>
					))}
				</ul>
			</div>
		</main>
	</body>
</html>
