---
import { jwtVerify } from 'jose';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';
import { db } from '../../lib/firebase';

const sessionCookie = Astro.cookies.get('admin_session');

if (!sessionCookie) {
  return Astro.redirect('/admin/login');
}

try {
  const jwtSecret = import.meta.env.JWT_SECRET || 'fallback_secret_for_dev_only';
  const secret = new TextEncoder().encode(jwtSecret);
  await jwtVerify(sessionCookie.value, secret);
} catch (err) {
  Astro.cookies.delete('admin_session', { path: '/' });
  return Astro.redirect('/admin/login');
}

let docs: any[] = [];
try {
	const snapshot = await db.collection('docs').get();
	docs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (e) {
	console.error('Error fetching docs:', e);
}
---

<html lang="en">
	<head>
		<SEO title="Manage Docs | AutcustDev" description="Admin Dashboard" noindex={true} />
	</head>
	<body>
		<main class="container admin-layout">
			<aside class="glass-panel" style="padding: 1.5rem;">
				<h2 style="font-size: 1.5rem; margin-bottom: 2rem;">Admin Panel</h2>
				<nav class="admin-sidebar">
					<a href="/admin" class="admin-nav-link">Dashboard</a>
					<a href="/admin/apps" class="admin-nav-link">Manage Apps</a>
					<a href="/admin/policies" class="admin-nav-link">Manage Policies</a>
					<a href="/admin/docs" class="admin-nav-link active">Manage Docs</a>
					<a href="/admin/settings" class="admin-nav-link">Settings</a>
				</nav>
				
				<div style="margin-top: auto; padding-top: 2rem;">
					<form action="/api/auth/logout" method="POST">
						<button type="submit" class="admin-nav-link" style="width: 100%; text-align: left; background: none; border: none; cursor: pointer; color: #ffffff;">Logout</button>
					</form>
				</div>
			</aside>
			
			<div class="content">
				<div class="glass-panel mb-4" style="display: flex; justify-content: space-between; align-items: center;">
					<div>
						<h1 style="font-size: 2rem; margin-bottom: 0;">Manage Documentations</h1>
						<p style="margin-bottom: 0;">Add, edit, or delete documentation pages.</p>
					</div>
					<button class="btn" onclick="openEditor()">+ Add New Doc</button>
				</div>

				<!-- Docs List -->
				<div id="docs-list" class="glass-panel">
					{docs.length === 0 ? (
						<p>No documentations found.</p>
					) : (
						<ul style="list-style: none; padding: 0; margin: 0;">
							{docs.map(doc => (
								<li style="padding: 1rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
									<div>
										<h3 style="margin: 0; font-size: 1.2rem;">{doc.title}</h3>
										<p style="margin: 0; font-size: 0.9rem; color: var(--text-muted);">Slug: {doc.slug}</p>
									</div>
									<div style="display: flex; gap: 0.5rem;">
										<button class="btn btn-secondary text-sm" onclick={`editDoc('${doc.slug}', '${doc.title.replace(/'/g, "\\'")}', \`${doc.content.replace(/`/g, '\\`')}\`)`}>Edit</button>
										<button class="btn btn-secondary text-sm" style="color: #e53e3e; border-color: rgba(229, 62, 62, 0.3);" onclick={`deleteDoc('${doc.slug}')`}>Delete</button>
									</div>
								</li>
							))}
						</ul>
					)}
				</div>

				<!-- Editor Form (Hidden by default) -->
				<div id="doc-editor" class="glass-panel" style="display: none; text-align: left;">
					<h2 id="editor-title" style="font-size: 1.5rem; margin-bottom: 1rem;">Add New Doc</h2>
					<form id="doc-form">
						<div class="form-group mb-2">
							<label class="form-label" for="slug">URL Slug</label>
							<input type="text" id="slug" class="form-input" placeholder="e.g. torrentx-privacy" required />
						</div>
						<div class="form-group mb-2">
							<label class="form-label" for="title">Title</label>
							<input type="text" id="title" class="form-input" placeholder="e.g. TorrentX Privacy Policy" required />
						</div>
						<div class="form-group mb-4">
							<label class="form-label" for="content">HTML Content</label>
							<textarea id="content" class="form-input" rows="15" placeholder="Write documentation content here in HTML format..." required style="font-family: monospace;"></textarea>
						</div>
						<div style="display: flex; gap: 1rem;">
							<button type="submit" class="btn">Save Doc</button>
							<button type="button" class="btn btn-secondary" onclick="closeEditor()">Cancel</button>
						</div>
						<div id="editor-msg" class="text-sm mt-2" style="display: none;"></div>
					</form>
				</div>
			</div>
		</main>

		<script is:inline>
			function openEditor() {
				document.getElementById('docs-list').style.display = 'none';
				document.getElementById('doc-editor').style.display = 'block';
				document.getElementById('editor-title').innerText = 'Add New Doc';
				document.getElementById('slug').value = '';
				document.getElementById('title').value = '';
				document.getElementById('content').value = '';
				document.getElementById('slug').readOnly = false;
				document.getElementById('editor-msg').style.display = 'none';
			}

			function editDoc(slug, title, content) {
				document.getElementById('docs-list').style.display = 'none';
				document.getElementById('doc-editor').style.display = 'block';
				document.getElementById('editor-title').innerText = 'Edit Doc';
				document.getElementById('slug').value = slug;
				document.getElementById('title').value = title;
				document.getElementById('content').value = content;
				document.getElementById('slug').readOnly = true;
				document.getElementById('editor-msg').style.display = 'none';
			}

			function closeEditor() {
				document.getElementById('doc-editor').style.display = 'none';
				document.getElementById('docs-list').style.display = 'block';
			}

			async function deleteDoc(slug) {
				if (!confirm(`Are you sure you want to delete the doc "${slug}"?`)) return;
				
				try {
					const res = await fetch('/api/admin/delete-doc', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ slug })
					});

					if (res.ok) {
						window.location.reload();
					} else {
						alert('Failed to delete doc.');
					}
				} catch (err) {
					alert('Network error.');
				}
			}

			const docForm = document.getElementById('doc-form');
			const editorMsg = document.getElementById('editor-msg');

			docForm?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const slug = document.getElementById('slug').value;
				const title = document.getElementById('title').value;
				const content = document.getElementById('content').value;
				
				const btn = docForm.querySelector('button[type="submit"]');
				const ogText = btn.innerText;
				btn.innerText = 'Saving...';
				btn.disabled = true;

				try {
					const res = await fetch('/api/admin/update-doc', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ slug, title, content })
					});

					if (res.ok) {
						window.location.reload();
					} else {
						editorMsg.innerText = 'Failed to save doc.';
						editorMsg.style.color = '#e53e3e';
						editorMsg.style.display = 'block';
					}
				} catch (err) {
					editorMsg.innerText = 'Network error.';
					editorMsg.style.color = '#e53e3e';
					editorMsg.style.display = 'block';
				} finally {
					btn.innerText = ogText;
					btn.disabled = false;
				}
			});
		</script>
	</body>
</html>
