---
import { jwtVerify } from 'jose';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';
import { db } from '../../lib/firebase';

// Server-side authentication check
const sessionCookie = Astro.cookies.get('admin_session');

if (!sessionCookie) {
  return Astro.redirect('/admin/login');
}

try {
  const jwtSecret = import.meta.env.JWT_SECRET || 'fallback_secret_for_dev_only';
  const secret = new TextEncoder().encode(jwtSecret);
  await jwtVerify(sessionCookie.value, secret);
} catch (err) {
  // Invalid or expired session
  Astro.cookies.delete('admin_session', { path: '/' });
  return Astro.redirect('/admin/login');
}

// Fetch home content from Firestore
let headline = '';
let description = '';
let appLinks: any[] = [];

try {
	const doc = await db.collection('site_content').doc('home').get();
	if (doc.exists) {
		const data = doc.data();
		headline = data?.headline || '';
		description = data?.description || '';
		appLinks = data?.appLinks || [];
	}
} catch (e) {
	console.error('Error fetching home content:', e);
}
---

<html lang="en">
	<head>
		<SEO 
			title="Dashboard | AutcustDev"
			description="Admin Dashboard"
			noindex={true}
		/>
	</head>
	<body>
		<main class="container admin-layout">
			<aside class="glass-panel" style="padding: 1.5rem;">
				<h2 style="font-size: 1.5rem; margin-bottom: 2rem;">Admin Panel</h2>
				<nav class="admin-sidebar">
					<a href="/admin" class="admin-nav-link active">Dashboard</a>
					<a href="/admin/policies" class="admin-nav-link">Manage Policies</a>
					<a href="/admin/settings" class="admin-nav-link">Settings</a>
				</nav>
				
				<div style="margin-top: auto; padding-top: 2rem;">
					<form action="/api/auth/logout" method="POST">
						<button type="submit" class="admin-nav-link" style="width: 100%; text-align: left; background: none; border: none; cursor: pointer; color: #ffffff;">Logout</button>
					</form>
				</div>
			</aside>
			
			<div class="content">
				<div class="glass-panel mb-4">
					<h1 style="font-size: 2rem; margin-bottom: 0;">Welcome Back</h1>
					<p style="margin-bottom: 0;">Here you can manage your website's main content.</p>
				</div>

				<div class="glass-panel" style="text-align: left;">
					<h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Edit Home Screen Content</h2>
					<form id="home-form">
						<div class="form-group">
							<label class="form-label" for="headline">Headline</label>
							<input type="text" id="headline" class="form-input mb-2" value={headline} required />
						</div>
						<div class="form-group mt-4">
							<label class="form-label" for="description">Description</label>
							<textarea id="description" class="form-input mb-2" rows="4" required>{description}</textarea>
						</div>

						<h3 style="font-size: 1.25rem; margin-top: 2rem; margin-bottom: 1rem; color: var(--accent-primary);">Manage App Links</h3>
						<p class="text-sm mb-2">The appropriate platform icon will be auto-detected from the URL.</p>
						<div id="app-links-container" style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1rem;">
							<!-- Dynamic rows added via JS -->
						</div>
						<button type="button" id="add-link-btn" class="btn mb-4" style="background: rgba(255,255,255,0.1); border: 1px dashed var(--border-color); color: var(--text-main); width: 100%; box-shadow: none;">+ Add App Link</button>

						<button type="submit" class="btn mt-4">Save All Changes</button>
						<div id="home-msg" class="text-sm mt-2" style="display: none;"></div>
					</form>
				</div>
			</div>
		</main>

		<script is:inline define:vars={{ initialAppLinks: appLinks }}>
			const homeForm = document.getElementById('home-form');
			const homeMsg = document.getElementById('home-msg');
			const linksContainer = document.getElementById('app-links-container');
			const addLinkBtn = document.getElementById('add-link-btn');

			let currentLinks = [...initialAppLinks];

			function renderLinks() {
				linksContainer.innerHTML = '';
				currentLinks.forEach((link, index) => {
					const row = document.createElement('div');
					row.style.display = 'flex';
					row.style.gap = '10px';
					row.style.alignItems = 'center';

					row.innerHTML = `
						<input type="text" class="form-input" placeholder="App Name (e.g. TorrentX)" value="${link.name || ''}" data-index="${index}" data-field="name" required style="flex: 1; padding: 0.75rem;" />
						<input type="url" class="form-input" placeholder="URL (e.g. https://play.google.com/...)" value="${link.url || ''}" data-index="${index}" data-field="url" required style="flex: 2; padding: 0.75rem;" />
						<button type="button" class="remove-btn" data-index="${index}" style="background: none; border: none; color: #e53e3e; cursor: pointer; padding: 0.5rem;" aria-label="Remove Link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
						</button>
					`;
					linksContainer.appendChild(row);
				});

				// Attach event listeners
				linksContainer.querySelectorAll('input').forEach(input => {
					input.addEventListener('input', (e) => {
						const target = e.target;
						const index = target.getAttribute('data-index');
						const field = target.getAttribute('data-field');
						currentLinks[index][field] = target.value;
					});
				});

				linksContainer.querySelectorAll('.remove-btn').forEach(btn => {
					btn.addEventListener('click', (e) => {
						const index = e.currentTarget.getAttribute('data-index');
						currentLinks.splice(index, 1);
						renderLinks();
					});
				});
			}

			addLinkBtn.addEventListener('click', () => {
				currentLinks.push({ name: '', url: '' });
				renderLinks();
			});

			// Initial render
			renderLinks();

			homeForm?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const headline = document.getElementById('headline').value;
				const description = document.getElementById('description').value;
				
				const btn = homeForm.querySelector('button');
				const ogText = btn!.innerText;
				btn!.innerText = 'Saving...';
				btn!.disabled = true;

				try {
					const res = await fetch('/api/admin/update-home', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ headline, description, appLinks: currentLinks })
					});

					if (res.ok) {
						homeMsg!.innerText = 'Changes saved successfully!';
						homeMsg!.style.color = '#48bb78';
					} else {
						homeMsg!.innerText = 'Failed to save changes.';
						homeMsg!.style.color = '#e53e3e';
					}
				} catch (err) {
					homeMsg!.innerText = 'Network error.';
					homeMsg!.style.color = '#e53e3e';
				} finally {
					homeMsg!.style.display = 'block';
					btn!.innerText = ogText;
					btn!.disabled = false;
					setTimeout(() => { homeMsg!.style.display = 'none'; }, 3000);
				}
			});
		</script>
	</body>
</html>
