---
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';
import { db } from '../../lib/firebase';

const { slug } = Astro.params;
if (!slug) {
	return Astro.redirect('/404');
}

let appData = null;
try {
	const doc = await db.collection('apps').doc(slug).get();
	if (doc.exists) {
		appData = doc.data();
	}
} catch (e) {
	console.error('Error fetching app info:', e);
}

if (!appData) {
	// Fallback check: Did the user accidentally link to a policy or doc using a relative link?
	try {
		const policyDoc = await db.collection('policies').doc(slug).get();
		if (policyDoc.exists) return Astro.redirect(`/policies/${slug}`);
		
		const docFile = await db.collection('docs').doc(slug).get();
		if (docFile.exists) return Astro.redirect(`/docs/${slug}`);
	} catch (e) {
		console.error('Error in fallback check:', e);
	}

	return Astro.redirect('/404');
}

const htmlContent = appData.content;
const updatedDate = appData.updatedAt ? new Date(appData.updatedAt).toDateString() : 'N/A';
---

<html lang="en">
	<head>
		<SEO 
			title={`${appData.name} | AutcustDev`}
			description={`Information about ${appData.name}.`}
			type="article"
		/>

		<!-- Analytics -->
		<script defer src="/_vercel/insights/script.js"></script>
	</head>
	<body>
		<main class="container">
			<div class="glass-panel mb-4">
				<a href="/" class="mb-4" style="display: inline-block;">&larr; Back to Home</a>
				<h1>{appData.name}</h1>
				<p class="text-sm text-muted">Last updated: {updatedDate}</p>
				<hr class="divider" />
				<div class="markdown-content" set:html={htmlContent}></div>
			</div>
		</main>
	</body>
</html>
