---
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<SEO 
			title="TorrentX Web-Client | AutcustDev"
			description="A fully functional client-side web torrent client."
		/>
		<script src="https://cdn.jsdelivr.net/npm/webtorrent@latest/webtorrent.min.js"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
		<style is:global>
            html, body {
                background-color: #000000 !important;
                color: #ffffff !important;
                font-family: 'Lora', serif !important;
                margin: 0;
                min-height: 100vh;
            }
        </style>
        <style>
			.container {
				max-width: 800px;
				margin: 0 auto;
				width: 100%;
                padding: 2rem;
                box-sizing: border-box;
			}
			h1 {
				text-align: center;
				margin-bottom: 2rem;
				font-size: 2.5rem;
                font-family: 'Lora', serif;
			}
            .back-link {
                color: #aaaaaa;
                text-decoration: none;
                display: inline-block;
                margin-bottom: 1rem;
                font-family: 'Lora', serif;
            }
            .back-link:hover {
                color: #ffffff;
            }
			.input-group {
				display: flex;
				gap: 1rem;
				margin-bottom: 2rem;
				flex-direction: column;
			}
            .helper-text {
                font-size: 0.9rem;
                color: #aaa;
                margin-top: -0.5rem;
                margin-bottom: 1rem;
            }
			input[type="text"] {
				width: 100%;
				padding: 1.2rem;
				border: 1px solid #333;
				background: #111;
				color: #fff;
				font-family: 'Lora', serif;
				border-radius: 8px;
				font-size: 1.1rem;
                box-sizing: border-box;
			}
            input[type="text"]:focus {
                outline: none;
                border-color: #555;
            }
			.actions {
				display: flex;
				gap: 1rem;
				justify-content: center;
			}
			button {
				padding: 0.8rem 2.5rem;
				background: #222;
				color: #fff;
				border: 1px solid #444;
				border-radius: 8px;
				cursor: pointer;
				font-family: 'Lora', serif;
				font-size: 1.1rem;
				transition: all 0.2s;
			}
			button:hover {
				background: #333;
				border-color: #666;
			}
            button:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }
			.status-panel {
				background: #111;
				border: 1px solid #222;
				border-radius: 12px;
				padding: 2rem;
				margin-top: 2rem;
				display: none;
			}
			.progress-bar-container {
				width: 100%;
				height: 12px;
				background: #000;
				border-radius: 6px;
				overflow: hidden;
				margin: 1.5rem 0;
                border: 1px solid #333;
			}
			.progress-bar {
				height: 100%;
				background: #ffffff;
				width: 0%;
				transition: width 0.2s;
			}
			.stats {
				display: flex;
				justify-content: space-between;
				font-size: 0.95rem;
				color: #ccc;
			}
			.files-list {
				margin-top: 2rem;
			}
			.file-item {
				padding: 0.75rem 0;
				border-bottom: 1px solid #222;
                display: flex;
                justify-content: space-between;
                align-items: center;
			}
            .file-item:last-child {
                border-bottom: none;
            }
            .file-name {
                word-break: break-all;
                padding-right: 1rem;
            }
            .file-actions button {
                padding: 0.4rem 1rem;
                font-size: 0.9rem;
            }
			#media-container {
				margin-top: 2rem;
				width: 100%;
                border-radius: 12px;
                overflow: hidden;
                background: #111;
			}
            #media-container video, #media-container audio {
                width: 100%;
                max-height: 70vh;
                display: block;
            }
            .error {
                color: #ff6b6b;
                margin-top: 1rem;
                text-align: center;
                font-weight: bold;
            }
		</style>
	</head>
	<body>
		<main class="container">
            <a href="/" class="back-link">&larr; Back to Home</a>
			<h1>TorrentX Web-Client</h1>
			
			<div class="input-group">
				<input type="text" id="torrentId" placeholder="Enter Magnet URI or Info Hash..." />
                <p class="helper-text">Note: Browser torrent clients can only connect to WebRTC peers (not standard TCP/UDP peers). If a torrent has no WebRTC seeds, it will not download. <a href="#" id="test-torrent-link" style="color: #66b3ff;">Test with a known working torrent.</a></p>
				<div class="actions">
					<button id="btn-download">Download</button>
					<button id="btn-watch">Watch</button>
				</div>
                <div id="error-message" class="error"></div>
			</div>

			<div class="status-panel" id="status-panel">
                <h3 style="margin-top: 0; font-family: 'Lora', serif; font-size: 1.5rem;" id="torrent-name">Loading...</h3>
				<div class="stats">
					<span id="speed-down">⬇ 0 B/s</span>
					<span id="speed-up">⬆ 0 B/s</span>
					<span id="peers-count">Peers: 0</span>
				</div>
				
				<div class="progress-bar-container">
					<div class="progress-bar" id="progress-bar"></div>
				</div>
				
				<div class="stats">
					<span id="progress-text">0%</span>
					<span id="downloaded-text">0 B / 0 B</span>
                    <span id="time-remaining"></span>
				</div>

				<div class="files-list" id="files-list"></div>
			</div>

			<div id="media-container"></div>
		</main>

		<script>
            let client = null;
			let currentTorrent = null;

			const torrentIdInput = document.getElementById('torrentId');
			const btnDownload = document.getElementById('btn-download');
			const btnWatch = document.getElementById('btn-watch');
			const statusPanel = document.getElementById('status-panel');
			const progressBar = document.getElementById('progress-bar');
			const progressText = document.getElementById('progress-text');
			const speedDown = document.getElementById('speed-down');
			const speedUp = document.getElementById('speed-up');
			const peersText = document.getElementById('peers-count');
			const downloadedText = document.getElementById('downloaded-text');
            const timeRemainingText = document.getElementById('time-remaining');
            const torrentName = document.getElementById('torrent-name');
			const filesList = document.getElementById('files-list');
			const mediaContainer = document.getElementById('media-container');
            const errorMessage = document.getElementById('error-message');

            const mediaExtensions = ['.mp4', '.webm', '.mkv', '.ogg', '.mp3', '.wav'];

			function formatBytes(bytes, decimals = 2) {
				if (!+bytes) return '0 B';
				const k = 1024;
				const dm = decimals < 0 ? 0 : decimals;
				const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
				const i = Math.floor(Math.log(bytes) / Math.log(k));
				return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
			}

            function showError(msg) {
                errorMessage.textContent = msg;
                setTimeout(() => errorMessage.textContent = '', 5000);
            }

            function initClient() {
                if (!client) {
                    client = new window.WebTorrent();
                }
            }

            function resetUI() {
                if (currentTorrent) {
                    currentTorrent.destroy();
                    currentTorrent = null;
                }
                statusPanel.style.display = 'block';
                mediaContainer.innerHTML = '';
                filesList.innerHTML = '';
                torrentName.textContent = 'Connecting to peers...';
                progressBar.style.width = '0%';
                progressText.textContent = '0%';
                btnDownload.disabled = true;
                btnWatch.disabled = true;
                errorMessage.textContent = '';
                speedDown.textContent = '⬇ 0 B/s';
                speedUp.textContent = '⬆ 0 B/s';
                peersText.textContent = 'Peers: 0';
                downloadedText.textContent = '0 B / 0 B';
                timeRemainingText.textContent = '';
            }

			function startTorrent(action) {
                if (!window.WebTorrent) {
                    showError('WebTorrent library is still loading. Please try again in a moment.');
                    return;
                }

				const torrentId = torrentIdInput.value.trim();
				if (!torrentId) {
                    showError('Please enter a valid Magnet URI.');
					return;
				}

                initClient();
                resetUI();

				client.add(torrentId, (torrent) => {
                    currentTorrent = torrent;
                    torrentName.textContent = torrent.name || 'Unknown Torrent';
                    btnDownload.disabled = false;
                    btnWatch.disabled = false;

					// Find media files
					const mediaFiles = torrent.files.filter(file => {
                        return mediaExtensions.some(ext => file.name.toLowerCase().endsWith(ext));
                    });

                    if (action === 'watch') {
                        if (mediaFiles.length === 0) {
                            showError('No playable media files found in this torrent.');
                            torrent.destroy();
                            statusPanel.style.display = 'none';
                            return;
                        }

                        // Play the largest media file
                        const largestMedia = mediaFiles.reduce((prev, current) => {
                            return (prev.length > current.length) ? prev : current;
                        });

                        // Render directly to the container
                        largestMedia.appendTo(mediaContainer);
                    }

                    // Render files list for download
                    torrent.files.forEach(file => {
                        const fileEl = document.createElement('div');
                        fileEl.className = 'file-item';
                        
                        const nameEl = document.createElement('span');
                        nameEl.className = 'file-name';
                        nameEl.textContent = `${file.name} (${formatBytes(file.length)})`;
                        
                        const actionsEl = document.createElement('div');
                        actionsEl.className = 'file-actions';

                        const downloadBtn = document.createElement('button');
                        downloadBtn.textContent = 'Save File';
                        downloadBtn.onclick = () => {
                            file.getBlobURL((err, url) => {
                                if (err) {
                                    console.error(err);
                                    showError('Failed to generate download link.');
                                    return;
                                }
                                const a = document.createElement('a');
                                a.href = url;
                                a.download = file.name;
                                a.click();
                            });
                        };

                        actionsEl.appendChild(downloadBtn);
                        fileEl.appendChild(nameEl);
                        fileEl.appendChild(actionsEl);
                        filesList.appendChild(fileEl);
                    });

					torrent.on('download', (bytes) => {
						const progress = Math.round(torrent.progress * 100 * 100) / 100;
						progressBar.style.width = `${progress}%`;
						progressText.textContent = `${progress}%`;
						
						speedDown.textContent = `⬇ ${formatBytes(torrent.downloadSpeed)}/s`;
						speedUp.textContent = `⬆ ${formatBytes(torrent.uploadSpeed)}/s`;
						peersText.textContent = `Peers: ${torrent.numPeers}`;
						
						downloadedText.textContent = `${formatBytes(torrent.downloaded)} / ${formatBytes(torrent.length)}`;
                        
                        if (torrent.timeRemaining) {
                            const remaining = Math.round(torrent.timeRemaining / 1000);
                            const minutes = Math.floor(remaining / 60);
                            const seconds = remaining % 60;
                            timeRemainingText.textContent = `ETA: ${minutes}m ${seconds}s`;
                        }
					});

					torrent.on('done', () => {
						progressBar.style.width = '100%';
						progressText.textContent = '100%';
                        timeRemainingText.textContent = 'Done';
                        speedDown.textContent = '⬇ 0 B/s';
					});
				});
			}

			btnDownload.addEventListener('click', () => startTorrent('download'));
			btnWatch.addEventListener('click', () => startTorrent('watch'));

            document.getElementById('test-torrent-link').addEventListener('click', (e) => {
                e.preventDefault();
                // Sintel, a free, open-source movie seeded by WebTorrent
                torrentIdInput.value = 'magnet:?xt=urn:btih:08ada5a7a6183aae1e09d831df6748d566095a10&dn=Sintel&tr=udp%3A%2F%2Fexplodie.org%3A6969&tr=udp%3A%2F%2Ftracker.coppersurfer.tk%3A6969&tr=udp%3A%2F%2Ftracker.empire-js.us%3A1337&tr=udp%3A%2F%2Ftracker.leechers-paradise.org%3A6969&tr=udp%3A%2F%2Ftracker.opentrackr.org%3A1337&tr=wss%3A%2F%2Ftracker.btorrent.xyz&tr=wss%3A%2F%2Ftracker.fastcast.nz&tr=wss%3A%2F%2Ftracker.openwebtorrent.com&ws=https%3A%2F%2Fwebtorrent.io%2Ftorrents%2F&xs=https%3A%2F%2Fwebtorrent.io%2Ftorrents%2Fsintel.torrent';
                startTorrent('watch');
            });

		</script>
	</body>
</html>
