---
// src/components/AppLink.astro
export interface Props {
  href: string;
  name: string;
}

const { href, name } = Astro.props;

let platform = "web";
if (href.includes("play.google.com")) {
  platform = "playstore";
} else if (href.includes("apps.apple.com")) {
  platform = "appstore";
} else if (href.includes("microsoft.com") || href.includes("windows")) {
  platform = "windows";
} else if (href.includes("github.com")) {
  platform = "github";
}
---

<a 
  href={href} 
  class="app-link-card" 
  target="_blank" 
  rel="noopener noreferrer"
  aria-label={`Download ${name} on ${platform}`}
>
  <div class="app-link-icon">
    {platform === 'playstore' && (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
    )}
    {platform === 'appstore' && (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"></path><path d="M10 2c1 .5 2 2 2 5"></path></svg>
    )}
    {platform === 'windows' && (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
    )}
    {platform === 'github' && (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
    )}
    {platform === 'web' && (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
    )}
  </div>
  <div class="app-link-info">
    <span class="app-name">{name}</span>
    <span class="app-platform">{platform === 'playstore' ? 'Google Play' : platform === 'appstore' ? 'App Store' : platform === 'windows' ? 'Microsoft Store' : platform === 'github' ? 'GitHub' : 'Web'}</span>
  </div>
  <div class="app-link-arrow">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </div>
</a>

<style>
  .app-link-card {
    display: flex;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--glass-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text-main);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    margin-bottom: 0.75rem;
    width: 100%;
  }

  .app-link-card:hover {
    background: var(--glass-bg-hover);
    transform: translateY(-2px) scale(1.02);
    border-color: var(--accent-primary);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .app-link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    margin-right: 1rem;
    color: var(--accent-primary);
  }

  .app-link-icon svg {
    width: 22px;
    height: 22px;
  }

  .app-link-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-align: left;
  }

  .app-name {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .app-platform {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .app-link-arrow {
    color: var(--text-muted);
    transition: transform 0.3s ease;
  }

  .app-link-card:hover .app-link-arrow {
    transform: translateX(4px);
    color: var(--accent-primary);
  }
</style>
